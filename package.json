{
  "name": "iraya-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "import:csv": "node scripts/import-csv.mjs"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.10.5",
    "typescript": "5.9.2",
    "@supabase/supabase-js": "^2.110.7",
    "dotenv": "^17.4.2",
    "csv-parse": "^7.0.1"
  },
  "engines": {
    "node": ">=18"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": "11.9.0"
    }
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}